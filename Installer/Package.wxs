<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!--  Per-user installer for Revit 2025 / 2026 / 2027                  -->
  <!--                                                                    -->
  <!--  Installs everything under %APPDATA%\Autodesk\Revit\Addins\YYYY\  -->
  <!--  No admin / UAC required.  Files only visible to the installing   -->
  <!--  user — does not write to Program Files or ProgramData.            -->
  <!--                                                                    -->
  <!--  Revit accepts add-in manifests from %APPDATA%\Autodesk\Revit\    -->
  <!--  Addins\YYYY\ for every version 2017+ including 2027 (per-user    -->
  <!--  path was unaffected by the 2027 all-users path change).           -->
  <!-- ════════════════════════════════════════════════════════════════ -->

  <Package Name="Ekahau WiFi Tools for Revit"
           Manufacturer="Ekahau Transfer"
           Version="2.4.0.0"
           UpgradeCode="F7A3B2C1-D4E5-6789-ABCD-0123456789AB"
           Scope="perUser"
           InstallerVersion="500">

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <WixVariable Id="WixUILicenseUrl" Value="" />

    <!-- ============================================================ -->
    <!--  Directory layout                                              -->
    <!--  AppDataFolder = %APPDATA% = C:\Users\<u>\AppData\Roaming     -->
    <!-- ============================================================ -->
    <StandardDirectory Id="AppDataFolder">
      <Directory Id="DIR_Autodesk" Name="Autodesk">
        <Directory Id="DIR_Revit" Name="Revit">
          <Directory Id="DIR_Addins" Name="Addins">

            <Directory Id="DIR_2025" Name="2025">
              <Directory Id="DIR_2025_Plugin" Name="EkahauWiFiTools" />
            </Directory>
            <Directory Id="DIR_2026" Name="2026">
              <Directory Id="DIR_2026_Plugin" Name="EkahauWiFiTools" />
            </Directory>
            <Directory Id="DIR_2027" Name="2027">
              <Directory Id="DIR_2027_Plugin" Name="EkahauWiFiTools" />
            </Directory>

          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- ============================================================ -->
    <!--  Revit 2025 — net8 build                                      -->
    <!-- ============================================================ -->
    <ComponentGroup Id="Cg_2025_Manifest" Directory="DIR_2025">
      <Component Id="Cmp_2025_Addin" Guid="A1111111-B222-C333-D444-E55555555525">
        <File Source="..\EkahauRevitPlugin\bin\Release\net8.0-windows\EkahauRevitPlugin.addin"
              Name="EkahauRevitPlugin.addin" KeyPath="yes" />
        <RegistryValue Root="HKCU"
                       Key="Software\EkahauTransfer\EkahauWiFiTools\Revit2025"
                       Name="installed" Type="integer" Value="1" />
      </Component>
    </ComponentGroup>
    <ComponentGroup Id="Cg_2025_Plugin" Directory="DIR_2025_Plugin">
      <Component Id="Cmp_2025_Dll" Guid="B2222222-C333-D444-E555-F66666666625">
        <File Source="..\EkahauRevitPlugin\bin\Release\net8.0-windows\EkahauRevitPlugin.dll"
              Name="EkahauRevitPlugin.dll" KeyPath="yes" />
      </Component>
      <Component Id="Cmp_2025_Deps" Guid="C3333333-D444-E555-F666-A77777777725">
        <File Source="..\EkahauRevitPlugin\bin\Release\net8.0-windows\EkahauRevitPlugin.deps.json"
              Name="EkahauRevitPlugin.deps.json" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ============================================================ -->
    <!--  Revit 2026 — net8 build (same DLL as 2025)                   -->
    <!-- ============================================================ -->
    <ComponentGroup Id="Cg_2026_Manifest" Directory="DIR_2026">
      <Component Id="Cmp_2026_Addin" Guid="A1111111-B222-C333-D444-E55555555526">
        <File Source="..\EkahauRevitPlugin\bin\Release\net8.0-windows\EkahauRevitPlugin.addin"
              Name="EkahauRevitPlugin.addin" KeyPath="yes" />
        <RegistryValue Root="HKCU"
                       Key="Software\EkahauTransfer\EkahauWiFiTools\Revit2026"
                       Name="installed" Type="integer" Value="1" />
      </Component>
    </ComponentGroup>
    <ComponentGroup Id="Cg_2026_Plugin" Directory="DIR_2026_Plugin">
      <Component Id="Cmp_2026_Dll" Guid="B2222222-C333-D444-E555-F66666666626">
        <File Source="..\EkahauRevitPlugin\bin\Release\net8.0-windows\EkahauRevitPlugin.dll"
              Name="EkahauRevitPlugin.dll" KeyPath="yes" />
      </Component>
      <Component Id="Cmp_2026_Deps" Guid="C3333333-D444-E555-F666-A77777777726">
        <File Source="..\EkahauRevitPlugin\bin\Release\net8.0-windows\EkahauRevitPlugin.deps.json"
              Name="EkahauRevitPlugin.deps.json" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ============================================================ -->
    <!--  Revit 2027 — net10 build                                     -->
    <!--  Uses the same per-user AppData path as 2025/2026.            -->
    <!--  (Revit 2027's all-users path change to Program Files only    -->
    <!--   affects the all-users location — per-user path is unchanged.)-->
    <!-- ============================================================ -->
    <ComponentGroup Id="Cg_2027_Manifest" Directory="DIR_2027">
      <Component Id="Cmp_2027_Addin" Guid="A1111111-B222-C333-D444-E55555555527">
        <File Source="..\EkahauRevitPlugin\bin\Release\net10.0-windows\EkahauRevitPlugin.addin"
              Name="EkahauRevitPlugin.addin" KeyPath="yes" />
        <RegistryValue Root="HKCU"
                       Key="Software\EkahauTransfer\EkahauWiFiTools\Revit2027"
                       Name="installed" Type="integer" Value="1" />
      </Component>
    </ComponentGroup>
    <ComponentGroup Id="Cg_2027_Plugin" Directory="DIR_2027_Plugin">
      <Component Id="Cmp_2027_Dll" Guid="B2222222-C333-D444-E555-F66666666627">
        <File Source="..\EkahauRevitPlugin\bin\Release\net10.0-windows\EkahauRevitPlugin.dll"
              Name="EkahauRevitPlugin.dll" KeyPath="yes" />
      </Component>
      <Component Id="Cmp_2027_Deps" Guid="C3333333-D444-E555-F666-A77777777727">
        <File Source="..\EkahauRevitPlugin\bin\Release\net10.0-windows\EkahauRevitPlugin.deps.json"
              Name="EkahauRevitPlugin.deps.json" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ============================================================ -->
    <Feature Id="MainFeature" Title="Ekahau WiFi Tools" Level="1">
      <ComponentGroupRef Id="Cg_2025_Manifest" />
      <ComponentGroupRef Id="Cg_2025_Plugin" />
      <ComponentGroupRef Id="Cg_2026_Manifest" />
      <ComponentGroupRef Id="Cg_2026_Plugin" />
      <ComponentGroupRef Id="Cg_2027_Manifest" />
      <ComponentGroupRef Id="Cg_2027_Plugin" />
    </Feature>

  </Package>
</Wix>
